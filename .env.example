# App Config
APP_NAME=BlackClap
DEBUG=True
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/blackclap

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/service-account.json

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_POST_MEDIA_CONTAINER=post-media
AZURE_PROFILE_CONTAINER=profile-images
AZURE_THUMBNAIL_CONTAINER=thumbnails
AZURE_TEMP_CONTAINER=temp
AZURE_SAS_EXPIRY_MINUTES=15

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT Security — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# Required — the app will not start without this set.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Email (SMTP) — used for password-reset OTP codes.
# If SMTP_HOST is unset, codes are logged instead of emailed (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=True
EMAIL_FROM=BlackClap <no-reply@blackclap.com>
