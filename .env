# App Config
APP_NAME=BlackClap
DEBUG=True
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/blackclap

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/service-account.json

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=blackclap-media
CLOUDFRONT_DOMAIN=your-cloudfront-domain.com

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT Security
JWT_SECRET_KEY=dev-secret-key-change-in-production-1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
